# vim: ft=swayconfig

# Variables
# =========

# Logo key. Use Mod1 for Alt. Mod3 is Hyper (CapsLock).
set $mod Super

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

# Your preferred terminal emulator
set $term uwsm app -- ghostty
# Your preferred application launcher
set $menu uwsm app -- vicinae toggle

set $out_left DP-3
set $out_middle DP-1
set $out_right DP-2

set $lua_scripts /home/atty/.config/scroll/scripts

# Startup
# =======
exec uwsm finalize SWAYSOCK I3SOCK SCROLLSOCK XCURSOR_SIZE XCURSOR_THEME
# exec uwsm app -- vicinae server
# exec $term

# Config only commands
# ====================
animations {
    enabled yes
    frequency_ms 8
}
bar {
    font "Noto Sans 14"
    mode hide
    tray_output none
    colors {
        background #00000000
    }
}
default_orientation auto
cursor_shake_magnify yes
layout_widths [0.16666666 0.33333333 0.5 0.666666667 1.0]
layout_heights [0.33333333 0.5 0.666666667 1.0]
swaybg_command -

# Config or runtime commands
# ==========================
client.focused #15439e #4b4b4b #e0e0e0 #2e9ef4 #15439e
client.focused_inactive #595959 #3b3b3b #e0e0e0 #2e9ef4 #595959
client.unfocused #595959 #1b1b1b #e0e0e0 #2e9ef4 #595959
default_border pixel 2
default_decoration border_radius 8 shadow on shadow_dynamic on
default_floating_border normal
# focus_follows_mouse no
focus_on_window_activation focus
focus_wrapping stay
font "Noto Sans 12"
# fullscreen_on_request layout
titlebar_border_radius 8
gaps inner 4
gaps outer 0
# xdg_activation_force true

# Input configuration
input type:keyboard {
    xkb_layout "us"
    xkb_options "caps:hyper"
    repeat_delay 300
    repeat_rate 30
}
input type:pointer {
    accel_profile adaptive
    pointer_accel 0
}
# seat

# Output configuration
output $out_left {
  resolution 3840x2160
  position 0,0
  scale 1.25
  transform 270
  subpixel rgb
  layout_type vertical
  layout_default_width 1
  layout_default_height 0.5
}
output $out_middle {
  resolution 5120x1440
  position 1800,1220
  scale 1
  allow_tearing yes
  subpixel rgb
  render_bit_depth 10
  layout_type horizontal
  layout_default_width 0.33333333
  layout_default_height 1
}
output $out_right {
  resolution 3840x2160
  position 6920,0
  scale 1.25
  transform 90
  subpixel rgb
  layout_type vertical
  layout_default_width 1
  layout_default_height 0.5
}

# xwayland_output_scale true









# ----






# Idle inhibit for fullscreen windows
for_window [all] inhibit_idle fullscreen



# ---- Workspace rules:
## Left
workspace secondary output $out_left
lua $lua_scripts/workspace_exec.lua secondary layout_default_width 1

## Right
workspace panel output $out_right
lua $lua_scripts/workspace_exec.lua panel workspace split v 0.66666666
lua $lua_scripts/workspace_exec.lua panel rename workspace 2 to strip
lua $lua_scripts/workspace_exec.lua panel layout_default_width 1

## Middle
#lua $lua_scripts/workspace_exec.lua 1 workspace split v 0.333333
workspace 1 output $out_middle
#lua $lua_scripts/workspace_exec.lua 1 layout_default_width 1

workspace --no-auto-back-and-forth 1

for_window [app_id="chrome-agimnkijcaahngcdmfeangaknmldooml-youtube"] {
    move container to workspace panel
    set_size h 1
    set_size v 0.33333333
}
for_window [app_id="chrome-lodlkdfmihgonocnmddehnfgiljnadcf-X"] {
    move container to workspace strip
    set_size h 1
    set_size v 1
    scale_content 0.8
}
for_window [class="^steam$"] {
    move container to workspace panel
    set_size h 1
    set_size v 0.33333333
}

for_window [app_id="app.zen_browser.zen"] {
    move container to workspace 1
#    set_size h 1
}

for_window [app_id="obsidian"] {
    move container to workspace secondary
}

for_window [app_id="gamescope"] {
    move container to workspace 1
    resize set width 2560px
    resize set height 1440px
}
for_window [title="Endfield"] {
    move container to workspace 1
#    fullscreen enable
}

include /home/atty/.config/scroll/config.d/*
